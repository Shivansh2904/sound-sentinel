# ============================================================
# SoundSentinel .gitignore
# ============================================================

# Node.js / Frontend
# ------------------
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Build artifacts
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*.local

# Editor / IDE
# ------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Python
# ------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Python virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb
!training/notebooks/*.ipynb

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ML / Training artifacts
# -----------------------
# Trained model weights (large, reproducible from train.py)
training/models/*.pkl
training/models/*.joblib

# ESC-50 dataset (large, download separately)
training/data/

# Generated evaluation plots
training/outputs/

# ONNX model is committed only if pre-trained (otherwise generated by train.py)
# Uncomment the line below to exclude it:
# public/model.onnx

# Logs
# ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS
# --
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
